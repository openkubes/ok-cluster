# cluster-config.yaml — OpenKubes Cluster Configuration
# Copy to <cluster-name>/cluster-config.yaml and adjust values.
# Run: make render CLUSTER=<cluster-name>

name: my-cluster
type: talos               # talos | ubuntu

# OS layer — managed by ok-linux
# https://github.com/openkubes/ok-linux
os:
  distribution: ok-linux
  profile: kubevirt       # kubevirt | baremetal | edge | gpu
  schematic_id: ce4c980550dd2ab1b17bbf2b08801c7eb59418eafe8f279833297925d67c7515
  # schematic_id is generated by ok-linux:
  #   make build PROFILE=kubevirt   (in ok-linux repo)
  # In a future release, render.py will resolve this automatically
  # from the ok-linux profile — no manual update needed.

controlPlane:
  replicas: 1             # 1 or 3 (HA)
  cores: 2
  memory: 4Gi
  disk: 20Gi

workers:
  replicas: 1
  cores: 2
  memory: 4Gi
  disk: 15Gi

versions:
  kubernetes: v1.32.0
  talos: v1.9.5

network:
  endpoint: auto          # auto = next free IP from MetalLB pool
  podCIDR: auto           # auto = next free /16 from 10.32.0.0/11
  serviceCIDR: auto       # auto = next free /20 from 10.96.0.0/12

# nodeSelector pins all VMs to a specific host node.
# Required for Talos clusters (local-path PVCs).
# Leave empty for no pinning (workers scheduled freely).
nodeSelector: ok-gpu      # kubernetes.io/hostname value

upgrade:
  strategy: blue-green    # blue-green | in-place
